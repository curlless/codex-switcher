{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Codex Switcher Desktop",
  "version": "0.2.5",
  "identifier": "com.onevoin.codexswitcher.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5000",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Codex Switcher Desktop",
        "width": 1440,
        "height": 940,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; font-src 'self' data:; img-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "useLocalToolsDir": false,
    "icon": [
      "icons/icon.ico"
    ],
    "resources": [],
    "copyright": "MIT License",
    "shortDescription": "Manage multiple Codex CLI accounts with usage-aware switching",
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "wix": {
        "language": "en-US"
      }
    },
    "createUpdaterArtifacts": false
  }
}
