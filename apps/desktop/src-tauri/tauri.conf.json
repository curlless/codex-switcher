{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Codex Switcher Desktop",
  "version": "0.1.0",
  "identifier": "com.onevoin.codexswitcher.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Codex Switcher Desktop",
        "width": 1440,
        "height": 940,
        "resizable": true,
        "fullscreen": false
      }
    ]
  }
}
